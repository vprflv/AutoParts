generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================
// Основные модели
// =============================================

model User {
  id         String  @id @default(cuid())
  telegramId String? @unique
  email      String? @unique
  password   String?
  name       String?
  username   String?
  avatarUrl  String?
  phone      String?
  provider   String?
  role       String  @default("USER")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ImportHistory ImportHistory[]
  orders        Order[]
  vehicles      Vehicle[]

  @@map("users")
}

model Product {
  id             String   @id
  createdAt      DateTime @default(now())
  updatedAt      DateTime
  name           String
  oem            String   @unique
  price          Decimal  @db.Decimal(10, 2)
  category       String?
  brand          String
  stock          Int      @default(0)
  images         String[] @default([])
  applicability  String[] @default([])
  crossNumbers   String[] @default([])
  description    String?
  specifications Json?
  searchText     String?
  active         Boolean  @default(true)

  order_items OrderItem[]

  @@map("products")
}

model Vehicle {
  id         String  @id @default(cuid())
  userId     String
  brand      String
  model      String
  year       Int
  engine     String?
  vin        String?
  bodyNumber String?
  notes      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("vehicles")
}

model Order {
  id String @id @default(cuid())

  userId          String?
  customerName    String
  customerPhone   String
  customerEmail   String?
  deliveryAddress String
  comment         String?
  totalAmount     Decimal
  status          OrderStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User?       @relation(fields: [userId], references: [id])
  items OrderItem[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("orders")
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  price     Decimal @db.Decimal(10, 2)

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@map("order_items")
}

model ImportHistory {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  userId     String
  type       String   @default("products")
  fileName   String?
  totalRows  Int      @default(0)
  added      Int      @default(0)
  updated    Int      @default(0)
  skipped    Int      @default(0)
  failed     Int      @default(0)
  errors     Json?
  resultData Json?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([userId])
  @@index([type])
  @@map("import_history")
}

model Feedback {
  id        String         @id
  createdAt DateTime       @default(now())
  updatedAt DateTime
  name      String?
  phone     String
  email     String?
  vin       String?
  carModel  String?
  message   String?
  status    FeedbackStatus @default(NEW)
  viewedAt  DateTime?

  @@map("feedbacks")
}

model MagicToken {
  id         String   @id @default(cuid())
  token      String   @unique
  telegramId String
  name       String?
  username   String?
  avatarUrl  String?
  expiresAt  DateTime
  used       Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([expiresAt])
  @@index([token])
  @@map("magic_tokens")
}

// =============================================
// Enums
// =============================================

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum FeedbackStatus {
  NEW
  IN_PROGRESS
  DONE
  REJECTED
}
